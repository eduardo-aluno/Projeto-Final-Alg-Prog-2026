<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="HollowKni" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/HollowKni" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add directory="C:/raylib/w64devkit/include" />
				</Compiler>
				<Linker>
					<Add option="-lraylib -lopengl32 -lgdi32 -lwinmm" />
					<Add directory="C:/raylib/w64devkit/lib" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/HollowKni" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
		</Compiler>
		<Unit filename="inimigo.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="inimigo.h" />
		<Unit filename="jogador.c">
			<Option compilerVar="CC" />
